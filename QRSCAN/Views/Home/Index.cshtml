@model List<QRSCAN.Models.Entities.MonAn>

@{
    ViewData["Title"] = "Trang chủ gọi món";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<div class="japan-home">
    <div id="cart-toast" class="cart-toast">
        Đã thêm món vào giỏ hàng
    </div>

    <nav class="japan-navbar">
        <div class="brand-box">
            <div class="brand-mark">ら</div>
            <div>
                <h2>KIMURA RAMEN</h2>
                <span>Japanese Ramen House</span>
            </div>
        </div>

        <div class="nav-menu">
            <a href="#about">About Us</a>
            <a href="#menu">Menu</a>
            <a href="#news">News</a>
            <a href="#location">Location</a>
        </div>

        <div class="nav-right">
            <div class="table-pill">
                @if (ViewBag.MaBan != null)
                {
                    <span>Bàn @ViewBag.MaBan</span>
                }
                else
                {
                    <span>Chưa có bàn</span>
                }
            </div>

            <div class="user-dropdown">
                <div class="user-icon-btn">
                    👤
                </div>

                <div class="user-dropdown-menu">
                    <div class="user-info">
                        <span>Tài khoản</span>
                        <strong>@ViewBag.HoTenKH</strong>
                    </div>

                    <a asp-controller="User" asp-action="Profile">Hồ sơ</a>
                    <a asp-controller="User" asp-action="LichSuDonHang">Lịch sử mua hàng</a>
                    <a asp-controller="User" asp-action="TrangThaiDonHang">Trạng thái đơn hàng</a>
                    <a asp-controller="GioHang" asp-action="Index">Giỏ hàng</a>
                    <a asp-controller="Account" asp-action="Logout">Đăng xuất</a>
                </div>
            </div>
        </div>
    </nav>

    <section class="hero-ramen">
        <div class="hero-overlay"></div>

        <div class="hero-center-content">
            <p class="hero-small">AUTHENTIC JAPANESE RAMEN</p>

            <h1>
                MORE FUN,<br />
                MORE RAMEN
            </h1>

            <p class="hero-subtitle">
                Conveying the richness and joy of Japanese dining
            </p>

            <p class="hero-welcome">
                Xin chào <strong>@ViewBag.HoTenKH</strong>, chọn món ramen yêu thích và gọi món ngay tại bàn.
            </p>

            @if (ViewBag.MaBan != null)
            {
                <div class="status-box success">
                    Bạn đang gọi món tại <strong>Bàn @ViewBag.MaBan</strong>
                </div>
            }
            else
            {
                <div class="status-box warning">
                    Chưa xác định bàn. Vui lòng quét mã QR tại bàn.
                </div>
            }
        </div>
    </section>

    <section class="menu-section" id="menu">
        <div class="section-title">
            <p>RAMEN MENU</p>
            <h2>Món ramen được yêu thích</h2>
        </div>

        <div class="menu-grid">
            @foreach (var mon in Model.Where(m => m.MaDanhMuc == 1 || m.MaDanhMuc == 2))
            {
                <div class="menu-card">
                    <img src="@mon.HinhAnh" alt="@mon.TenMon" />

                    <div class="menu-content">
                        <span class="tag">
                            @mon.DanhMucMon?.TenDanhMuc
                        </span>

                        <h3>@mon.TenMon</h3>

                        <p>@mon.MoTa</p>

                        <div class="menu-bottom">
                            <strong>@mon.DonGia.ToString("N0")đ</strong>

                            <button type="button"
                                    class="add-cart-btn"
                                    data-ma-mon="@mon.MaMon">
                                +
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="drink-dessert-section">
        <div class="section-title">
            <p>DRINK & DESSERT</p>
            <h2>Đồ uống và tráng miệng</h2>
        </div>

        <div class="small-menu-grid">
            @foreach (var mon in Model.Where(m => m.MaDanhMuc == 4 || m.MaDanhMuc == 5))
            {
                <div class="small-item">
                    <img src="@mon.HinhAnh" alt="@mon.TenMon" />

                    <div class="small-item-info">
                        <h3>@mon.TenMon</h3>
                        <span>@mon.DonGia.ToString("N0")đ</span>
                    </div>

                    <button type="button"
                            class="add-cart-btn small-add-btn"
                            data-ma-mon="@mon.MaMon">
                        +
                    </button>
                </div>
            }
        </div>
    </section>

    <section class="info-section" id="about">
        <div class="section-title">
            <p>ABOUT US</p>
            <h2>Về KIMURA RAMEN</h2>
        </div>

        <p>
            KIMURA RAMEN là mô hình quán ramen Nhật sử dụng hệ thống gọi món bằng mã QR.
            Khách hàng có thể xem menu, chọn món, thêm vào giỏ hàng và theo dõi trạng thái món ngay tại bàn.
        </p>
    </section>

    <section class="info-section" id="news">
        <div class="section-title">
            <p>NEWS</p>
            <h2>Tin tức mới</h2>
        </div>

        <p>
            Cập nhật món mới, chương trình ưu đãi và các thông báo mới nhất từ KIMURA RAMEN.
        </p>
    </section>

    <section class="info-section" id="location">
        <div class="section-title">
            <p>LOCATION</p>
            <h2>Địa chỉ cửa hàng</h2>
        </div>

        <p>
            Chi nhánh demo: 123 Nguyễn Văn Cừ, Quận 5, TP. Hồ Chí Minh.
        </p>
    </section>

    <footer class="japan-footer">
        <div>
            <h3>KIMURA RAMEN</h3>
            <p>Hệ thống gọi món bằng mã QR cho quán ramen Nhật.</p>
        </div>

        <div>
            <h4>Chức năng</h4>
            <p>Menu</p>
            <p>Giỏ hàng</p>
            <p>Trạng thái món</p>
        </div>

        <div>
            <h4>Thông tin</h4>
            <p>Giá chỉ dùng cho demo môn học.</p>
            <p>Một số món có thể thay đổi tùy cửa hàng.</p>
        </div>
    </footer>
</div>

@section Scripts {
    <script>
        const addCartUrl = '@Url.Action("ThemVaoGio", "GioHang")';

        function showCartToast(message) {
            const toast = document.getElementById("cart-toast");

            if (!toast) {
                return;
            }

            toast.innerText = message || "Đã thêm món vào giỏ hàng";
            toast.classList.add("show");

            setTimeout(function () {
                toast.classList.remove("show");
            }, 1800);
        }

        document.querySelectorAll(".add-cart-btn").forEach(function (button) {
            button.addEventListener("click", async function () {
                const maMon = button.getAttribute("data-ma-mon");

                button.disabled = true;
                button.innerText = "✓";

                try {
                    const formData = new FormData();
                    formData.append("maMon", maMon);

                    const response = await fetch(addCartUrl, {
                        method: "POST",
                        body: formData,
                        headers: {
                            "X-Requested-With": "XMLHttpRequest"
                        }
                    });

                    const contentType = response.headers.get("content-type");

                    if (!contentType || !contentType.includes("application/json")) {
                        throw new Error("Server không trả JSON");
                    }

                    const result = await response.json();

                    if (result.success) {
                        showCartToast(result.message);
                    } else {
                        showCartToast(result.message || "Không thêm được món vào giỏ hàng.");
                    }
                } catch (error) {
                    console.error(error);
                    showCartToast("Không thêm được món vào giỏ hàng.");
                }

                setTimeout(function () {
                    button.disabled = false;
                    button.innerText = "+";
                }, 500);
            });
        });
    </script>
}